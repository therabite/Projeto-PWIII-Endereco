@model AplicacaoBanco.Models.Endereco

@{
    ViewData["Title"] = "Cadastro cliente";
}

<h1>Cadastro de endereço</h1>

<form asp-action="Cadastrar" asp-controller="Home" method="post">
    <main role="main">
        <section class="container" style="margin-top: 50px">
            <div class="row justify-content-center">
                <aside class="col-sm-8 col-md-6">

                    <div id="code_register_1">
                        <div class="card">
                            <header class="card-header">
                                <h4 class="card-title mt-2">Cadastro</h4>
                            </header>

                            <article class="card-body">

                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label asp-for="CEP">CEP</label>
                                        <input type="text" asp-for="CEP" class="no-cep cep form-control" />
                                        <span asp-validation-for="CEP"></span>
                                        <div class="alert alert-danger" style="display:none;"></div>
                                    </div>

                                    <div class="form-group col-md-6">
                                        <label asp-for="Estado">Estado</label>
                                        <input type="text" asp-for="Estado" readonly class="form-control" />
                                        <span asp-validation-for="Estado"></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label asp-for="Cidade">Cidade</label>
                                        <input type="text" asp-for="Cidade" readonly class="form-control" />
                                        <span asp-validation-for="Cidade"></span>
                                    </div>

                                    <div class="form-group col-md-6">
                                        <label asp-for="Bairro">Bairro</label>
                                        <input type="text" asp-for="Bairro" readonly class="form-control" />
                                        <span asp-validation-for="Bairro"></span>
                                    </div>
                                </div>

                                <div class="form-group col-md-12">
                                    <label asp-for="Logradouro">Endereco</label>
                                    <input type="text" asp-for="Logradouro" class="form-control" />
                                    <span asp-validation-for="Logradouro"></span>
                                </div>

                                <div class="row">
                                    <div class="form-group col-md-8">
                                        <label asp-for="Complemento">Complemento</label>
                                        <input type="text" asp-for="Complemento" class="form-control" />
                                        <span asp-validation-for="Complemento"></span>
                                    </div>

                                    <div class="form-group col-md-4">
                                        <label asp-for="Numero">Numero</label>
                                        <input type="text" asp-for="Numero" class="form-control" />
                                        <span asp-validation-for="Numero"></span>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <button type="submit" class="btn btn-primary btn-block">Cadastrar</button>
                                </div>

                            </article>

                            <div class="border-top card-body text-center">
                                Já tem um conta?
                                <a asp-action="Login" asp-controller="Home">Entre</a>
                            </div>
                        </div>
                    </div>

                </aside>
            </div>
        </section>
    </main>
</form>

<div class="align-content-center text-center mt-3">
    <a asp-action="Index">Cancelar</a>
</div>

@section Scripts {
    @await Html.RenderPartialAsync("_ValidationScriptsPartial");
}